APP_ENV=development
APP_SECRET_KEY=change-me
PUBLIC_BASE_URL=http://localhost:8000
NOTION_HOME_URL=https://www.notion.so/your-main-page
# Optional compatibility alias for older deployments:
# NOTION_PAGE=https://www.notion.so/your-main-page

NOTION_TOKEN=secret_xxx
NOTION_SAMPLES_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_RESULTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PEOPLE_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

ONEDRIVE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONEDRIVE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONEDRIVE_CLIENT_SECRET=change-me
ONEDRIVE_AUTH_MODE=client_credentials
ONEDRIVE_PUBLIC_CLIENT=false
ONEDRIVE_DRIVE_ID=required-for-client-credentials
ONEDRIVE_REFRESH_TOKEN=required-only-for-delegated-refresh
ONEDRIVE_ROOT_FOLDER=SampleTracker

BACKLOG_DIR=./backlog
ENABLE_BACKLOG_VIEW=false
BACKLOG_READ_LIMIT=50
MAX_UPLOAD_MB=200
MAX_UPLOAD_FILES=12
MAX_UPLOAD_FILE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.csv,.doc,.docx,.gif,.jpeg,.jpg,.json,.pdf,.png,.ppt,.pptx,.tif,.tiff,.txt,.webp,.xls,.xlsx,.zip
